{
  "name": "shy-keenan-archive",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node ./scripts/dev/simple-static-server.mjs",
    "dev:5173": "cross-env PORT=5173 node ./scripts/dev/simple-static-server.mjs",
    "dev:stack": "tsx scripts/dev/start-full-stack.ts",
    "build": "vite build",
    "build:gh-pages": "cross-env VITE_DEPLOY_TARGET=github-pages NODE_ENV=development vite build",
    "build:scale": "cross-env VITE_DEPLOY_TARGET=fasthosts-scale NODE_ENV=production vite build",
    "preview": "vite preview",
    "preview:gh-pages": "cross-env VITE_DEPLOY_TARGET=github-pages vite preview",
    "test": "playwright test",
    "test:e2e": "powershell.exe scripts/start-dev-then-e2e.ps1",
    "test:e2e:sh": "bash scripts/start-dev-then-e2e.sh",
    "test:e2e:update": "playwright test --update-snapshots",
    "server": "npx -y tsx watch server/index.ts",
    "server:dev": "npx -y tsx watch server/index.ts",
    "ops:bible": "pwsh -NoLogo -Command \"Start-Process (Resolve-Path 'docs/bible/v2/index.html')\"",
    "deploy:remote": "npm run build && pwsh -NoLogo -File scripts/remote/deploy_open_ssh.ps1 -Alias shy -HostName ssh.shykeenan.uk -User csh3326584 -Domain shykeenan.uk -RemotePath /htdocs/shykeenan.uk -Port 1022 -UploadDist -NoBuild",
    "deploy:gh-pages": "npm run build:gh-pages && gh-pages -d dist",
    "deploy:scale": "npm run build:scale && pwsh -NoLogo -File scripts/remote/deploy_fasthosts_scale.ps1",
    "deploy:scale:auto": "npm run build:scale && pwsh -NoLogo -File scripts/remote/automated_deploy.ps1",
    "deploy:backend": "pwsh -NoLogo -File scripts/remote/deploy_backend_only.ps1",
    "deploy-script": "node scripts/deploy.mjs",
    "start": "npm run start:prod",
    "start:prod": "cross-env NODE_ENV=production tsx server/index.ts",
    "start:webapp": "tsx server/index.ts",
    "audit:deps": "node build-guardian/bin/audit-deps.js",
    "analyze": "ANALYZE=true vite build",
    "analyze:bundle": "node scripts/analyze-bundle.mjs",
    "verify:phase1": "node scripts/verify-phase1-optimizations.mjs",
    "lighthouse": "node scripts/lighthouse-performance.mjs",
    "smoke:navbar": "node scripts/smoke-navbar.mjs",
    "deploy:backend:nginx": "pwsh -NoLogo -File scripts/remote/deploy_backend_compose.ps1",
    "deploy:backend:caddy": "pwsh -NoLogo -File scripts/remote/deploy_backend_compose.ps1 -UseCaddy",
    "deploy:release": "pwsh -NoLogo -File scripts/remote/deploy_release.ps1",
    "routes:coverage": "node scripts/routeCoverage.js",
    "deps:prune": "npx ts-prune",
    "env:unused": "node scripts/unusedEnv.js",
    "security:gate": "node build-guardian/bin/security-gate.js",
    "security:pentest": "node scripts/security/run-pentest.mjs",
    "security:pentest:external": "RUN_EXTERNAL_TOOLS=1 node scripts/security/run-pentest.mjs",
    "validate:mcp": "node scripts/validate_mcp_args.mjs",
  "launch:mcp:dry": "node scripts/launch-chrome-mcp.mjs --dry-run",
  "launch:mcp": "node scripts/launch-chrome-mcp.mjs",
    "mcp:devtools": "node scripts/mcp/start-devtools.mjs",
    "lint": "eslint src server --ext .ts,.tsx --max-warnings 0",
    "security:scan": "npm run audit:deps",
    "quality": "npm run build && npm run security:gate && npm run security:scan",
    "guardian:build": "npm run build",
    "guardian:deploy": "npm run deploy:remote",
    "guardian:smoke": "smoke-test http://localhost:5173",
    "guardian:security": "npm audit --audit-level=moderate",
    "guardian:quality": "npm run build && npm run security:gate && npm run audit:deps && npm test",
    "build:frontend": "vite build",
    "build:server": "tsc -p server/tsconfig.prod.json && node ./scripts/fix-dist-extensions.mjs ./dist-server",
    "build:prod": "npm run build:frontend",
    "fix:dist": "node ./scripts/fix-dist-extensions.mjs ./dist-server",
    "start:prod:js": "node dist-server/index.js",
    "security:audit": "npm audit --audit-level=moderate || node -e \"process.exit(0)\"",
    "affiliate:test": "tsx scripts/affiliate_smoke.ts",
    "readiness:check": "node scripts/readiness/checklist.mjs",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "backup:db": "bash scripts/backup/db_backup.sh",
    "backup:files": "bash scripts/backup/files_backup.sh",
    "backup:all": "bash scripts/backup/backup_all.sh",
    "release:archive": "bash scripts/releases/archive_release.sh",
    "export:published": "node scripts/releases/export_published.mjs",
    "check:clerk": "node scripts/clerk/check.mjs",
    "perf:rewrite": "tsx scripts/performance/ai-query-rewrite.ts",
    "local-prod": "pwsh -NoProfile -File scripts/start-production-local.ps1",
    "local-prod:build": "pwsh -NoProfile -File scripts/start-production-local.ps1 -Build",
    "local-prod:clean": "pwsh -NoProfile -File scripts/start-production-local.ps1 -Clean -Build",
    "ultra-deploy": "pwsh -NoLogo -File scripts/ultra-deploy.ps1",
    "final-test": "npm test && npx playwright test",
    "devtools:verify": "node scripts/dev/verify-devtools-attach.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-ses": "^3.919.0",
    "@clerk/backend": "^2.12.0",
    "@clerk/clerk-react": "^5.47.0",
    "@phosphor-icons/react": "^2.0.15",
    "@prisma/client": "^6.16.1",
    "@radix-ui/react-slot": "^1.0.2",
    "@types/node-fetch": "^2.6.13",
    "@vendia/serverless-express": "^4.10.4",
    "chrome-devtools-mcp": "^0.9.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.0.0",
    "compression": "^1.7.5",
    "connect-redis": "^9.0.0",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dompurify": "^3.3.0",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "express-rate-limit": "^8.1.0",
    "express-session": "^1.17.3",
    "lucide-react": "^0.548.0",
    "node-fetch": "^3.3.2",
    "papaparse": "^5.5.3",
    "pino": "^10.1.0",
    "pino-loki": "^2.6.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.9.4",
    "react-share": "^5.2.2",
    "redis": "^5.9.0",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.0",
    "@playwright/test": "^1.48.2",
    "@shykeenan/build-guardian": "file:build-guardian",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.16",
    "@types/express": "^5.0.5",
    "@types/express-rate-limit": "^6.0.2",
    "@types/express-session": "^1.18.2",
    "@types/imagemin": "^9.0.1",
    "@types/imagemin-gifsicle": "^7.0.4",
    "@types/imagemin-jpegtran": "^5.0.4",
    "@types/imagemin-mozjpeg": "^8.0.4",
    "@types/imagemin-optipng": "^5.2.4",
    "@types/imagemin-svgo": "^11.0.0",
    "@types/imagemin-webp": "^7.0.3",
    "@types/node": "^24.9.2",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^8.46.2",
    "@typescript-eslint/parser": "^8.46.2",
    "@vitejs/plugin-react": "^5.0.4",
    "@vitest/coverage-v8": "^4.0.4",
    "@vitest/snapshot": "^4.0.4",
    "@vitest/ui": "^4.0.4",
    "autoprefixer": "^10.4.20",
    "axe-core": "^4.9.1",
    "chrome-launcher": "^1.2.1",
    "cross-env": "^10.1.0",
    "cssnano": "^7.1.1",
    "eslint": "^9.38.0",
    "eslint-plugin-react": "^7.35.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-security": "^3.0.1",
    "gh-pages": "^6.3.0",
    "imagemin-mozjpeg": "^10.0.0",
    "imagemin-pngquant": "^10.0.0",
    "jsdom": "^27.0.1",
    "jszip": "^3.10.1",
    "lighthouse": "^13.0.1",
    "msw": "^2.11.1",
    "openai": "^6.7.0",
    "postcss": "^8.5.6",
    "prisma": "^6.16.1",
    "puppeteer": "^24.19.0",
    "qrcode.react": "^4.2.0",
    "rollup-plugin-visualizer": "^6.0.5",
    "sharp": "^0.34.4",
    "supertest": "^7.0.0",
    "tailwindcss": "^4.1.16",
    "tsx": "^4.6.2",
    "typescript": "^5.9.3",
    "vite": "^7.1.7",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-imagemin": "^0.6.1",
    "vitest": "^4.0.4"
  }
}
